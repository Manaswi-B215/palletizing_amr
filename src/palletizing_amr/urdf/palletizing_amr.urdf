<?xml version="1.0"?>

<robot name="palletizing_amr">

  <!-- ===================================================== -->
  <!-- BASE LINK -->
  <!-- ===================================================== -->

  <link name="base_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="18.0"/>

      <inertia
        ixx="0.53"
        iyy="0.53"
        izz="0.48"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0.245" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.40 0.49"/>
      </geometry>
    </collision>

  </link>


  <!-- ===================================================== -->
  <!-- FORKLIFT -->
  <!-- ===================================================== -->

  <link name="forklift">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="6.0"/>

      <inertia
        ixx="0.55"
        iyy="0.08"
        izz="0.62"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0.245" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/forklift.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 1.00 0.10"/>
      </geometry>
    </collision>

  </link>


  <!-- ===================================================== -->
  <!-- MAIN WHEELS -->
  <!-- ===================================================== -->

  <link name="wheel_ML1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_ML1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_ML2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_ML2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_MR1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_MR1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_MR2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_MR2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <!-- FRONT WHEELS -->

  <link name="wheel_FLI">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FLI.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_FLO">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FLO.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_FRI">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FRI.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_FRO">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FRO.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <!-- ===================================================== -->
  <!-- JOINTS -->
  <!-- ===================================================== -->

  <joint name="revolute_wheel_MR1" type="continuous">
    <origin xyz="0.17695 -0.10295 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_MR1"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>

  <joint name="revolute_wheel_ML1" type="continuous">
    <origin xyz="-0.17565 -0.10295 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_ML1"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>

  <joint name="revolute_wheel_MR2" type="continuous">
    <origin xyz="0.17693 -0.01296 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_MR2"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>

  <joint name="revolute_wheel_ML2" type="continuous">
    <origin xyz="-0.17565 -0.01295 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_ML2"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="2.0" friction="1.0"/>
  </joint>


  <joint name="revolute_wheel_FRI" type="continuous">
    <origin xyz="0.14185 1.07475 -0.26250" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_FRI"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="1.5" friction="0.8"/>
  </joint>

  <joint name="revolute_wheel_FLI" type="continuous">
    <origin xyz="-0.13815 1.07475 -0.26250" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_FLI"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="1.5" friction="0.8"/>
  </joint>

  <joint name="revolute_wheel_FRO" type="continuous">
    <origin xyz="0.22685 1.07475 -0.26250" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_FRO"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="1.5" friction="0.8"/>
  </joint>

  <joint name="revolute_wheel_FLO" type="continuous">
    <origin xyz="-0.23315 1.07475 -0.26250" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_FLO"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="1.5" friction="0.8"/>
  </joint>


  <joint name="prismatic_forklift" type="prismatic">
    <origin xyz="-0.00058 0.72555 -0.18250" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="forklift"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="0.0"
      upper="0.20"
      effort="1000"
      velocity="0.5"/>

    <dynamics damping="8.0" friction="3.0"/>
  </joint>

</robot>