<?xml version="1.0"?>

<robot name="palletizing_amr">

  <!-- ===================================================== -->
  <!-- BASE LINK -->
  <!-- ===================================================== -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="18.0"/>
      <inertia
        ixx="0.53"
        iyy="0.53"
        izz="0.48"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/base_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.40 0.40 0.49"/>
      </geometry>
    </collision>

  </link>


  <!-- ===================================================== -->
  <!-- FORKLIFT (BEHIND THE MAIN BODY) -->
  <!-- ===================================================== -->

  <link name="forklift">

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="6.0"/>

      <inertia
        ixx="0.55"
        iyy="0.08"
        izz="0.62"
        ixy="0"
        ixz="0"
        iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/forklift.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 1.00 0.10"/>
      </geometry>
    </collision>

  </link>


  <!-- ===================================================== -->
  <!-- MAIN WHEELS -->
  <!-- ===================================================== -->

  <link name="wheel_ML1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_ML1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_ML2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_ML2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_MR1">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_MR1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_MR2">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.45"/>
      <inertia ixx="0.00018" iyy="0.00009" izz="0.00009"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_MR2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.028" length="0.028"/>
      </geometry>
    </collision>
  </link>


  <!-- FORKLIFT WHEELS -->

  <link name="wheel_FLI">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FLI.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_FLO">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FLO.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_FRI">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FRI.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <link name="wheel_FRO">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.12"/>
      <inertia ixx="0.00002" iyy="0.00001" izz="0.00001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://palletizing_amr/meshes/wheel_FRO.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.014" length="0.014"/>
      </geometry>
    </collision>
  </link>


  <!-- ===================================================== -->
  <!-- JOINTS -->
  <!-- ===================================================== -->

  <joint name="revolute_wheel_MR1" type="continuous">
    <origin xyz="0.17695 -0.10295 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_MR1"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" velocity="15"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="revolute_wheel_ML1" type="continuous">
    <origin xyz="-0.17565 -0.10295 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_ML1"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" velocity="15"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="revolute_wheel_MR2" type="continuous">
    <origin xyz="0.17693 -0.01296 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_MR2"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" velocity="15"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <joint name="revolute_wheel_ML2" type="continuous">
    <origin xyz="-0.17565 -0.01295 -0.24950" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="wheel_ML2"/>
    <axis xyz="1 0 0"/>
    <limit effort="100" velocity="15"/>
    <dynamics damping="0.1" friction="0.1"/>
  </joint>


  <joint name="revolute_wheel_FRI" type="continuous">
    <origin xyz="0.14243 0.34920 -0.08000" rpy="0 0 0"/>
    <parent link="forklift"/>
    <child link="wheel_FRI"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="revolute_wheel_FLI" type="continuous">
    <origin xyz="-0.13758 0.34920 -0.08000" rpy="0 0 0"/>
    <parent link="forklift"/>
    <child link="wheel_FLI"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="revolute_wheel_FRO" type="continuous">
    <origin xyz="0.22743 0.34920 -0.08000" rpy="0 0 0"/>
    <parent link="forklift"/>
    <child link="wheel_FRO"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <joint name="revolute_wheel_FLO" type="continuous">
    <origin xyz="-0.23258 0.34920 -0.08000" rpy="0 0 0"/>
    <parent link="forklift"/>
    <child link="wheel_FLO"/>
    <axis xyz="1 0 0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>


  <link name="lidar_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <link name="camera_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.08 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.08 0.05"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_link"/>
    <origin xyz="0.18 0.0 0.22" rpy="0 0 0"/>
  </joint>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.22 0.0 0.16" rpy="0 0 0"/>
  </joint>

  <joint name="prismatic_forklift" type="prismatic">
    <origin xyz="-0.00058 0.72555 -0.18250" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="forklift"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="0.0"
      upper="0.20"
      effort="1000"
      velocity="0.5"/>

    <dynamics damping="0.1" friction="0.1"/>
  </joint>

  <!-- ===================================================== -->
  <!-- WHEEL FRICTION -->
  <!-- ===================================================== -->

  <gazebo reference="base_link">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="forklift">
    <material>Gazebo/White</material>
  </gazebo>

  <gazebo reference="wheel_ML1">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>

  <gazebo reference="wheel_ML2">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>

  <gazebo reference="wheel_MR1">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>

  <gazebo reference="wheel_MR2">
    <material>Gazebo/DarkGrey</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
    <minDepth>0.001</minDepth>
    <maxVel>1.0</maxVel>
  </gazebo>

  <gazebo reference="wheel_FLI">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.1</mu1>
    <mu2>0.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="wheel_FLO">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.1</mu1>
    <mu2>0.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="wheel_FRI">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.1</mu1>
    <mu2>0.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="wheel_FRO">
    <material>Gazebo/DarkGrey</material>
    <mu1>0.1</mu1>
    <mu2>0.0</mu2>
    <kp>10000.0</kp>
    <kd>10.0</kd>
  </gazebo>

  <gazebo reference="lidar_link">
    <sensor name="lidar" type="gpu_lidar">
      <topic>/scan</topic>
      <gz_frame_id>lidar_link</gz_frame_id>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>10.0</max>
          <resolution>0.01</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="camera" type="camera">
      <topic>/camera/image_raw</topic>
      <gz_frame_id>camera_link</gz_frame_id>
      <update_rate>30</update_rate>
      <camera>
        <horizontal_fov>1.047</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>10.0</far>
        </clip>
      </camera>
    </sensor>
  </gazebo>

  <ros2_control name="GazeboSimSystem" type="system">

    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="revolute_wheel_ML1">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="revolute_wheel_ML2">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="revolute_wheel_MR1">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="revolute_wheel_MR2">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="prismatic_forklift">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <gazebo>
    <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">

      <parameters>/home/mb/amr_ws/install/palletizing_amr/share/palletizing_amr/config/controller.yaml</parameters>
    </plugin>
  </gazebo>

</robot>